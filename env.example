# the-gaffer — environment variables
# Copy this file to .env and fill in your values
# .env is in .gitignore — never commit it

# ── Google Calendar ────────────────────────────────────────────────────────
# Paste the entire contents of your service account JSON key file as a
# single line (the JSON object, not a file path).
# Generate at: Google Cloud Console → IAM → Service Accounts → Keys → Add Key
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# The Calendar ID to sync fixtures into.
# For a dedicated calendar: Google Calendar → Settings → [Calendar] → Calendar ID
# For your primary calendar: use your Gmail address
CALENDAR_ID=your-calendar-id@group.calendar.google.com

# ── Fixture source ─────────────────────────────────────────────────────────
FIXTURE_URL=https://www.adjfa.org.uk/fixtureslge/1020

# Must match the team name exactly as it appears on the fixtures page
TEAM_NAME=Blackburn Football Club (2012)

# ── Scheduling ─────────────────────────────────────────────────────────────
# How often to sync, in minutes. 360 = every 6 hours.
UPDATE_FREQUENCY=360

# ── Optional ──────────────────────────────────────────────────────────────
DRY_RUN=false
DEBUG=false
